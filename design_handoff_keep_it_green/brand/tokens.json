{
  "brand": "Keep It Green",
  "color": {
    "spring":   { "hex": "#18C964", "role": "Primary — mark, CTAs, accents" },
    "forest":   { "hex": "#0C3B2A", "role": "Dark surface — hero, machine panels" },
    "sun":      { "hex": "#FFC83D", "role": "Reward accent — points, badges, coins" },
    "mint":     { "hex": "#DCF1E2", "role": "Tint surface" },
    "paper":    { "hex": "#F6F7F1", "role": "App / page background" },
    "charcoal": { "hex": "#13201A", "role": "Primary text" },
    "muted":    { "hex": "#6B7A72", "role": "Secondary text" }
  },
  "typography": {
    "display": { "family": "Space Grotesk", "weights": [400, 500, 700], "use": "headings, numbers, labels" },
    "body":    { "family": "Hanken Grotesk", "weights": [400, 500, 600, 700], "use": "body copy" },
    "scale": {
      "display":  { "size": 52, "weight": 700, "tracking": "-0.02em" },
      "h1":       { "size": 32, "weight": 700, "tracking": "-0.02em" },
      "subtitle": { "size": 22, "weight": 500 },
      "body":     { "size": 17, "weight": 400, "lineHeight": 1.7 },
      "label":    { "size": 13, "weight": 500, "tracking": "0.14em", "transform": "uppercase" }
    }
  },
  "radius": { "token": "28%", "card": 20, "pill": 999 },
  "motion": {
    "easeSpring": "cubic-bezier(.2,.8,.3,1.4)",
    "principles": ["Springy overshoot on actions", "Points always count up", "Leaf gently grows — never stiff, never slow"]
  }
}
